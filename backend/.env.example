# Conexión a MongoDB Atlas
# Copia este archivo a .env y reemplaza con tu connection string

# Opción 1: URI completa (si la contraseña tiene @, #, etc., codifícala: @ → %40, # → %23)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/habitos?retryWrites=true&w=majority&appName=Cluster0

# Opción 2: User y contraseña por separado (evita codificar la contraseña en la URI)
# MONGODB_USER=tu_usuario
# MONGODB_PASS=tu_contraseña
# MONGODB_URI=mongodb+srv://cluster.xxxxx.mongodb.net/habitos?retryWrites=true&w=majority&appName=Cluster0

# Puerto del servidor. Para frontend Semana 2 usar PORT=3001
PORT=3001

# JWT para login (Semana 4). En producción usa un secreto fuerte.
JWT_SECRET=tu-clave-secreta-muy-segura
JWT_EXPIRE=7d

# Producción / Vercel: origen del frontend (coma si varios). Ej: https://tu-app.vercel.app
# ALLOWED_ORIGINS=https://tu-frontend.vercel.app
